# =============================================
# VARIABLES DE ENTORNO - BACKEND (Render)
# =============================================
# Configura estas variables en Render > Environment

PORT=8000

# Firebase API Key (la misma que usas en el frontend)
FIREBASE_API_KEY=tu_firebase_api_key

# URL del frontend de verificación (en producción será tu dominio de Render)
FRONTEND_VERIFY_URL=https://TU-APP.onrender.com/verify
